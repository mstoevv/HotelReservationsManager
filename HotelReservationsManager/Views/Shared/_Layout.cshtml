<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HotelReservationsManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HotelReservationsManager.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @* Логото води към Login, ако не си влязъл, или към Home, ако си вътре *@
                <a class="navbar-brand" asp-area="" asp-controller="@(User.Identity.IsAuthenticated ? "Home" : "Account")" asp-action="@(User.Identity.IsAuthenticated ? "Index" : "Login")">HotelReservationsManager</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @* Показваме менютата само ако има логнат потребител *@
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Rooms" asp-action="Index">Стаи</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Reservations" asp-action="Index">Резервации</a>
                            </li>

                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Clients" asp-action="Index">Клиенти</a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-bold" asp-area="" asp-controller="Users" asp-action="Index">Служители</a>
                                </li>
                            }
                        }
                    </ul>

                    @* Дясната част - Потребителска информация *@
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-dark me-2">
                                    Здравей, <strong>@User.Identity.Name</strong>
                                    <small class="text-muted">
                                        (@if (User.IsInRole("Admin")) {
                                        <span>Админ</span>
                                    }
                                         else if (User.IsInRole("Employee"))
                                    {

                                        <span>Служител</span>
                                    }
                                    else
                                    {

                                        <span>Гост</span>
                                    }
                                    )
                                </small>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-link text-danger" asp-controller="Account" asp-action="Logout">Изход</a>
                        </li>
                    }
                        else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Вход</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Регистрация</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container text-center">
        &copy; 2026 - HotelReservationsManager
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>