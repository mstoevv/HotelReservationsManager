@model IEnumerable<HotelReservationsManager.Models.Domain.User>

@{
    ViewData["Title"] = "Управление на служители";
}

<h2>Персонал и отчетност</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="filter" value="@ViewBag.Filter" class="form-control" placeholder="Търси по име или имейл..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Търси</button>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-success">Добави нов служител</a>
        </div>
    </div>
</form>

<table class="table table-hover border">
    <thead class="table-dark">
        <tr>
            <th>Потребител</th>
            <th>Имена</th>
            <th>Email</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @* Показваме само хората с IsActive = true или самия админ *@
        @foreach (var item in Model.Where(u => u.IsActive || u.Username.ToLower() == "admin"))
        {
            <tr>
                <td><strong>@item.Username</strong></td>
                <td>@item.FirstName @item.LastName</td>
                <td>@item.Email</td>
                <td>
                    @if (item.Username.ToLower() == "admin")
                    {
                        <span class="badge bg-danger">Администратор</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Активен Служител</span>
                    }
                </td>
                <td>
                    <div class="btn-group">
                        @* Бутонът, който показва какво е резервирал този служител *@
                        <a asp-controller="Reservations" asp-action="ByEmployee" asp-route-employeeId="@item.Id" class="btn btn-sm btn-info text-white">
                            Виж резервации
                        </a>
                        
                        @if (item.Username.ToLower() != "admin")
                        {
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да премахнете този служител?');" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger ms-1">Премахни</button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-center mt-3">
    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a asp-action="Index" asp-route-pageIndex="@i" asp-route-filter="@ViewBag.Filter"
           class="btn btn-sm mx-1 @(i == ViewBag.PageIndex ? "btn-dark" : "btn-outline-dark")">@i</a>
    }
</div>