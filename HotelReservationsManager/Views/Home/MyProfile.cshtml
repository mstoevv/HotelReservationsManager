@model HotelReservationsManager.Models.Domain.Client

@{
    ViewData["Title"] = "Моят Профил";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4>🪪 Лични данни</h4>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-1">👤</div>
                        <h3 class="mt-2">@Model.FirstName @Model.LastName</h3>
                        <span class="badge bg-info text-dark">Регистриран Гост</span>
                    </div>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Email:</strong>
                            <span>@Model.Email</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Телефон:</strong>
                            <span>@Model.PhoneNumber</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Статус:</strong>
                            <span>@(Model.IsAdult ? "Възрастен" : "Дете")</span>
                        </li>
                    </ul>

                    <div class="d-grid gap-2 mt-4">
                        <a asp-controller="Clients" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактирай данните си</a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>