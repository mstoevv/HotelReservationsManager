@{
    ViewData["Title"] = "Начало";
}

<div class="container mt-4">
    <div class="jumbotron p-5 mb-4 bg-light rounded-3 shadow-sm text-center">
        <h1 class="display-4">Добре дошли, @User.Identity.Name!</h1>
        <p class="lead">Управлявайте вашите хотелски услуги бързо и лесно.</p>
        <hr class="my-4">
        <p>Днес е @DateTime.Now.ToString("dd MMMM yyyy") г.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center py-4">
                <div class="card-body">
                    <div class="display-3 mb-3">📅</div>
                    <h5 class="card-title">Резервации</h5>
                    <p class="card-text text-muted">
                        @(User.IsInRole("Guest") ? "Вижте и управлявайте вашите резервации." : "Управлявайте всички хотелски резервации.")
                    </p>
                    <a asp-controller="Reservations" asp-action="Index" class="btn btn-primary px-4">Влез</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center py-4">
                <div class="card-body">
                    <div class="display-3 mb-3">🏨</div>
                    <h5 class="card-title">Стаи</h5>
                    <p class="card-text text-muted">Разгледайте свободните стаи и техните удобства.</p>
                    <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary px-4">Разгледай</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center py-4">
                <div class="card-body">
                    @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                    {
                        <div class="display-3 mb-3">👥</div>
                        <h5 class="card-title">Клиенти</h5>
                        <p class="card-text text-muted">Управление на базата данни с гости.</p>
                        <a asp-controller="Clients" asp-action="Index" class="btn btn-primary px-4">Управлявай</a>
                    }
                    else
                    {
                        <div class="display-3 mb-3">👤</div>
                        <h5 class="card-title">Моят Профил</h5>
                        <p class="card-text text-muted">Вашите лични данни и информация за контакт.</p>
                        <a asp-controller="Home" asp-action="MyProfile" class="btn btn-outline-secondary px-4">Виж детайли</a>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="alert alert-info shadow-sm d-flex justify-content-between align-items-center p-4">
                    <div>
                        <h5 class="mb-1">Административен панел</h5>
                        <p class="mb-0">Имате пълен достъп до управлението на персонала и системата.</p>
                    </div>
                    <a asp-controller="Users" asp-action="Index" class="btn btn-info text-white">Управление на персонал</a>
                </div>
            </div>
        </div>
    }
</div>