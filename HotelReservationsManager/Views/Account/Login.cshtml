@{
    Layout = "_Layout"; // Или null, ако искаш чиста страница без менюта
    ViewData["Title"] = "Вход в системата";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h4>Хотелски Мениджмънт</h4>
            </div>
            <div class="mt-3 text-center">
                <p>Нямате профил? <a asp-action="Register">Регистрирайте се тук</a></p>
            </div>
            <div class="card-body">
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="All" class="text-danger"></div>
                    
                    <div class="form-group mb-3">
                        <label class="control-label">Потребителско име</label>
                        <input name="username" class="form-control" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Парола</label>
                        <input name="password" type="password" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Влез</button>
                </form>
            </div>
        </div>
    </div>
</div>