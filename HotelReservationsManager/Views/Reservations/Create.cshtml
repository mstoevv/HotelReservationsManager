@model HotelReservationsManager.Models.Domain.Reservation

@{
    ViewData["Title"] = "Нова резервация";
}

<h2>Нова резервация</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" id="reservationForm">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="control-label">Избери стая (само свободни)</label>
                    <select asp-for="RoomId" class="form-control" asp-items="ViewBag.Rooms"></select>
                    <span asp-validation-for="RoomId" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CheckInDate" class="control-label">Дата на настаняване</label>
                    <input asp-for="CheckInDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="CheckInDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CheckOutDate" class="control-label">Дата на освобождаване</label>
                    <input asp-for="CheckOutDate" type="date" class="form-control" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="CheckOutDate" class="text-danger"></span>
                </div>
            </div>

            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-primary text-white">Изберете гости (Вас и придружаващите)</div>
                <div class="card-body" id="clientsContainer" style="max-height: 200px; overflow-y: auto;">
                    @if (ViewBag.Clients != null)
                    {
                        foreach (var client in (IEnumerable<HotelReservationsManager.Models.Domain.Client>)ViewBag.Clients)
                        {
                            <div class="form-check border-bottom py-1">
                                <input class="form-check-input" type="checkbox" name="selectedClients" value="@client.Id"
                                       id="client_@client.Id"
                                @(User.IsInRole("Guest") && (client.Email == User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value) ? "checked" : "")>
                                
                                <label class="form-check-label" for="client_@client.Id">
                                    @client.FirstName @client.LastName (@(client.IsAdult ? "Възрастен" : "Дете"))
                                </label>
                            </div>
                        }
                    }
                </div>

                <div class="card-footer bg-light">
                    <p class="mb-2 small fw-bold text-primary">➕ Добави нов човек към твоята група:</p>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <input type="text" id="qFirstName" class="form-control form-control-sm" placeholder="Име">
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="qLastName" class="form-control form-control-sm" placeholder="Фамилия">
                        </div>
                        <div class="col-md-3">
                            <select id="qIsAdult" class="form-select form-select-sm">
                                <option value="true">Възрастен</option>
                                <option value="false">Дете</option>
                            </select>
                        </div>
                        <div class="col-md-1 text-end">
                            <button type="button" onclick="quickAddClient()" class="btn btn-sm btn-success w-100">Add</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group form-check mb-2">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="HasBreakfast" /> Включена закуска
                </label>
            </div>

            <div class="form-group form-check mb-4">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsAllInclusive" /> All Inclusive
                </label>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success px-4">Създай резервация</button>
                <a asp-action="Index" class="btn btn-secondary px-4">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function quickAddClient() {
            const firstName = document.getElementById('qFirstName').value;
            const lastName = document.getElementById('qLastName').value;
            const isAdult = document.getElementById('qIsAdult').value === "true";

            if (!firstName || !lastName) {
                alert("Моля, попълнете имената на госта.");
                return;
            }

            // Изпращаме данните към контролера чрез AJAX
            fetch('/Clients/CreateQuick', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ firstName: firstName, lastName: lastName, isAdult: isAdult })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Добавяме новия човек динамично в списъка
                        const container = document.getElementById('clientsContainer');
                        const labelText = isAdult ? "Възрастен" : "Дете";
                        const newHtml = `
                                <div class="form-check border-bottom py-1">
                                    <input class="form-check-input" type="checkbox" name="selectedClients" value="${data.id}" id="client_${data.id}" checked>
                                    <label class="form-check-label" for="client_${data.id}">
                                        ${firstName} ${lastName} (${labelText})
                                    </label>
                                </div>`;
                        container.insertAdjacentHTML('beforeend', newHtml);

                        // Изчистваме полетата за въвеждане
                        document.getElementById('qFirstName').value = '';
                        document.getElementById('qLastName').value = '';
                    } else {
                        alert("Грешка при добавянето.");
                    }
                })
                .catch(error => console.error('Error:', error));
        }
    </script>
}