@model HotelReservationsManager.Models.Domain.Room

@{
    ViewData["Title"] = "Добави нова стая";
}

<h2>Добави нова стая</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Number" class="control-label">Номер на стая</label>
                <input asp-for="Number" class="form-control" />
                <span asp-validation-for="Number" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Type" class="control-label">Тип стая</label>
                <select asp-for="Type" class="form-control">
                    <option value="Две единични легла">Две единични легла</option>
                    <option value="Апартамент">Апартамент</option>
                    <option value="Двойно легло">Двойно легло</option>
                    <option value="Пентхаус">Пентхаус</option>
                    <option value="Мезонет">Мезонет</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Capacity" class="control-label">Капацитет (легла)</label>
                <input asp-for="Capacity" type="number" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PriceAdultBed" class="control-label">Цена за възрастен</label>
                <input asp-for="PriceAdultBed" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="PriceAdultBed" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PriceChildBed" class="control-label">Цена за дете</label>
                <input asp-for="PriceChildBed" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="PriceChildBed" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success">Запази</button>
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}