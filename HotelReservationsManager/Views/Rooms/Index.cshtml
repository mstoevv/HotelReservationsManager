@model IEnumerable<HotelReservationsManager.Models.Domain.Room>

@{
    ViewData["Title"] = "Нашите Стаи";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🏨 Нашите Стаи</h2>
        @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
        {
            <a asp-action="Create" class="btn btn-success">Добави Нова Стая</a>
        }
    </div>

    @if (User.IsInRole("Guest"))
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var room in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">Стая №@room.Number</h5>
                                <span class="badge @(room.IsFree ? "bg-success" : "bg-danger")">
                                    @(room.IsFree ? "Свободна" : "Заета")
                                </span>
                            </div>
                            <h6 class="card-subtitle mb-3 text-muted">Тип: @room.Type</h6>
                            
                            <p class="card-text">
                                <strong>Капацитет:</strong> @room.Capacity души<br />
                                <small class="text-muted">Перфектна за Вашия престой.</small>
                            </p>

                            <div class="mt-auto">
                                <hr>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="h5 mb-0 text-primary">@room.PriceAdultBed лв.</span>
                                        <div class="text-muted" style="font-size: 0.8rem;">за възрастен / нощ</div>
                                    </div>
                                    @if (room.IsFree)
                                    {
                                        <a asp-controller="Reservations" asp-action="Create" asp-route-roomId="@room.Id" class="btn btn-sm btn-primary">Резервирай</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>№</th>
                        <th>Тип</th>
                        <th>Капацитет</th>
                        <th>Цена (Възр./Дете)</th>
                        <th>Статус</th>
                        <th>Действия / Информация</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Number</strong></td>
                            <td>@item.Type</td>
                            <td>@item.Capacity души</td>
                            <td>@item.PriceAdultBed / @item.PriceChildBed лв.</td>
                            <td>
                                <span class="badge @(item.IsFree ? "bg-success" : "bg-danger")">
                                    @(item.IsFree ? "Свободна" : "Заета")
                                </span>
                            </td>
                            <td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редактирай</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Изтриване на стая?')">
                                        <button type="submit" class="btn btn-sm btn-danger">Изтрий</button>
                                    </form>
                                }

                                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                {
                                    <a asp-controller="Reservations" asp-action="Index" asp-route-roomId="@item.Id" class="btn btn-sm btn-info text-white">
                                        📅 Виж заетост
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>